# Copy to .env (never commit .env)

IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

REDIS_URL=redis://127.0.0.1:6379

# Optional: Prisma / Postgres for budget cloud API
# DATABASE_URL=postgres://...
# BUDGET_TABLE_NAME=dalali_budget_state
# BUDGET_PG_POOL_MAX=5
# BUDGET_PG_IDLE_MS=30000
# BUDGET_PG_CONN_MS=15000
# BUDGET_USER_ID_MIN_LEN=8
# BUDGET_USER_ID_MAX_LEN=128

# PORT=8787
# PORTFOLIO_POLL_MS=120000
# PORTFOLIO_REDIS_KEY=dalali:portfolio:payload
# IBKR_GETSTATEMENT_WAIT_MS=5000
# IBKR_FLEX_DIRECT_BASE=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService

# =============================================================================
# Third-party macro & market data (optional — wire routes when implemented)
# Server-only: load in api/.env or repo root .env (never expose as VITE_*).
# =============================================================================
#
# FRED (St. Louis Fed) — https://fred.stlouisfed.org/docs/api/fred/
#   - Auth: Authorization: Bearer <key> (request from https://fredaccount.stlouisfed.org/apikeys).
#   - JSON API: categories, releases, series, observations, search.
#   - Use case here: policy rates, inflation (e.g. CPI/PCE series ids), GDP, unemployment — each indicator is a series id.
#
# Tiingo — https://api.tiingo.com/documentation/general/connecting
#   - REST: Authorization: Token <token> or ?token= — EOD (incl. adj close), news, crypto, forex, IEX endpoints, fundamentals, dividends, splits, search.
#   - WebSocket: realtime crypto / forex / IEX; subscribe messages + ~30s heartbeats (messageType A/U/D/I/E/H).
#
# Alpaca — https://docs.alpaca.markets/docs/streaming-market-data
#   - HTTP headers: APCA-API-KEY-ID and APCA-API-SECRET-KEY (use the paper key pair for paper hosts).
#   - Market data: REST historical trades, quotes, bars; WebSocket wss://stream.data.alpaca.markets/... — feed must match subscription (e.g. iex, sip, delayed_sip).
#   - Trading API (paper vs live) uses separate base URLs and key pairs from the dashboard.
#   - There is no single “backtest” REST endpoint: use historical bars + your strategy code and optionally paper trading for simulated orders.
#
FRED_API_KEY=
TIINGO_API_TOKEN=

ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Set when using paper credentials and paper REST/stream hosts (implementation chooses URLs from this + Alpaca docs).
# ALPACA_PAPER=1
# Must match your Alpaca market data subscription (e.g. iex, sip, delayed_sip).
# ALPACA_DATA_FEED=iex
# Optional overrides if defaults change or you need sandbox (see Alpaca docs for current hostnames).
# ALPACA_DATA_REST_URL=https://data.alpaca.markets
# ALPACA_DATA_STREAM_URL=wss://stream.data.alpaca.markets
