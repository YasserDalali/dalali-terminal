# =============================================================================
# FRONTEND (Vite) — use on laptop + on Vercel
# =============================================================================
# Vercel: do NOT set IBKR_FLEX_TOKEN / IBKR_FLEX_QUERY_ID on the frontend project —
# production builds ignore them (they used to leak into the bundle and trigger /ibkr-flex 404).
# Use VITE_USE_PORTFOLIO_API=1 + VITE_PORTFOLIO_API_BASE only.
# =============================================================================
# Direct Flex in browser (token visible in devtools — prefer API mode for production)
# VITE_IBKR_FLEX_TOKEN=
# VITE_IBKR_FLEX_QUERY_ID=
# VITE_IBKR_FLEX_FIXTURE_URL=/dalali-finance.xml

# Redis-backed portfolio + budget APIs (no IBKR secrets in the browser bundle)
VITE_USE_PORTFOLIO_API=1

# Local: leave empty — Vite proxies /api → http://127.0.0.1:8787 (see vite.config.ts)
# Vercel: set to your Render API URL (no trailing slash)
# VITE_PORTFOLIO_API_BASE=https://your-service.onrender.com

VITE_PORTFOLIO_POLL_MS=30000

# =============================================================================
# BACKEND — local: repo root .env OR api/.env (see api/README.md)
# On Render: set these in the service Environment tab (never commit real values)
# =============================================================================
# IBKR_FLEX_TOKEN=
# IBKR_FLEX_QUERY_ID=
# REDIS_URL=redis://127.0.0.1:6379
# DATABASE_URL=postgres://...   # optional, budget cloud
# PORT=8787
# PORTFOLIO_POLL_MS=120000
# PORTFOLIO_REDIS_KEY=dalali:portfolio:payload
# IBKR_FLEX_DIRECT_BASE=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService



# .env  (never commit this file)
#
# Vercel: set VITE_PORTFOLIO_API_BASE=https://YOUR-SERVICE.onrender.com (no trailing slash).
#         Do not put IBKR / Redis / DATABASE secrets in Vercel if the browser only talks to Render.
# Local API: npm run server:dev loads this file first, then api/.env if present.
#
IBKR_FLEX_TOKEN=147214634041479887698416
IBKR_FLEX_QUERY_ID=1457186

# Prisma Cloud / Postgres — used only by server (npm run server); never exposed to the browser
DATABASE_URL=postgres://7482cc19e02ce3199ed6cdb7bbea3cf8ad556f1387c391c2e543d502e73e46c2:sk_UO0fyLeCWbNPyj6tM9TCi@db.prisma.io:5432/postgres?sslmode=require

# Redis Cloud — portfolio API cache (PORTFOLIO_POLL_MS). Use redis:// for this endpoint (plain TCP on 11718).
REDIS_URL=redis://default:1VkgsgdBcf8G6hTciFuVWg8XFaWfsVuu@redis-11718.crce202.eu-west-3-1.ec2.cloud.redislabs.com:11718

# --- Browser (Vite) ---
# Direct Flex in browser (token visible in devtools — prefer API mode for production)
# VITE_IBKR_FLEX_TOKEN=147214634041479887698416
# VITE_IBKR_FLEX_QUERY_ID=1457186
# VITE_IBKR_FLEX_FIXTURE_URL=/dalali-finance.xml

# Redis-backed portfolio API (no IBKR secrets in the bundle)
VITE_USE_PORTFOLIO_API=1
# Leave empty to use same-origin /api (Vite dev proxies to 8787)
# VITE_PORTFOLIO_API_BASE=http://localhost:8787
VITE_PORTFOLIO_POLL_MS=30000
